# Cloudflare Pages Headers — controla cache por tipo de arquivo

# HTML: nunca cachear (sempre versão fresca)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Service Worker e manifest: nunca cachear
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

# Protocolo (dados do dia): sempre fresh
/protocolo.json
  Cache-Control: public, max-age=0, must-revalidate

# Versão do app: nunca cachear (precisa estar sempre fresh para detectar updates)
/version.json
  Cache-Control: public, max-age=0, must-revalidate

# CSS: cache curto (5 min) — versionado via ?v=N
/css/*
  Cache-Control: public, max-age=300, must-revalidate

# JS: nunca cachear — dirige comportamento dinâmico (link do PDF do dia,
# protocolo, etc). Cache de 5min já atrasou a propagação de um fix em
# PWA instalado no celular (15/07/26).
/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Ícones e imagens: cache longo (1 dia)
/icons/*
  Cache-Control: public, max-age=86400

# PDFs em /pdfs/: cache longo
/pdfs/*
  Cache-Control: public, max-age=86400

# PDFs na raiz (tutorial, anuncio): versionados via ?v=N no link, mas
# forçar revalidação mesmo assim — nome de arquivo fixo já causou PDF
# desatualizado em cache de navegador/CDN (assinante via Android)
/*.pdf
  Cache-Control: public, max-age=0, must-revalidate
